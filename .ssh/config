Host *
    # Prefer Ed25519, then ECDSA
    IdentityFile ~/.ssh/id_ed25519

    # Harden key exchange and ciphers
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com

    # Keep connections alive (drop dead ones after ~45s)
    ServerAliveInterval 15
    ServerAliveCountMax 3

    # Don't hash known hosts (easier to debug)
    HashKnownHosts no

    # Prevent agent forwarding by default (enable per-host if needed)
    ForwardAgent no

    # Verify host key DNS records if available
    VerifyHostKeyDNS ask
