#!/usr/bin/env bash
# cybr-sync — make the cybr theming components you use available locally.
#
# For each component: clone it into the gitignored cache (if missing), and
# recreate any symlinks the integration needs (the symlinks live in ~/.config
# but are NOT tracked in ~/.cfg, so they must be regenerated on a fresh machine).
#
# The component lines at the bottom ARE your manifest + selective install:
# comment a line out to not use that component.
#
# Update a component's upstream:   git -C ~/.local/share/cybrdots/<name> pull
# Then re-run this script if the update added files you symlink.
set -euo pipefail
CACHE="${XDG_DATA_HOME:-$HOME/.local/share}/cybrdots"

clone() { # name  repo_url
  local dir="$CACHE/$1"
  [[ -d "$dir/.git" ]] || git clone --depth=1 "$2" "$dir"
}
link() { # src(relative to cache)  dest(absolute)
  mkdir -p "$(dirname "$2")"
  ln -sfn "$CACHE/$1" "$2"
}

# ── cybr-hyprland — theme only ───────────────────────────────────────────
# ~/.config/hypr/hyprland.conf sources <cache>/cybr-hyprland/theme.conf, which
# internally sources ~/.config/hypr/vars.conf — so vars.conf is symlinked in.
clone cybr-hyprland https://github.com/cybrcore/cybr-hyprland.git
link  cybr-hyprland/vars.conf "$HOME/.config/hypr/vars.conf"

