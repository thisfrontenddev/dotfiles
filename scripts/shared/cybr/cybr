#!/usr/bin/env bash
set -uo pipefail
source "$(cd "$(dirname "$0")" && pwd)/lib.sh"

cmd="${1:-}"; shift || true
case "$cmd" in
  list|enable|disable|sync|update|status|diff)
    "cybr::cmd_$cmd" "$@" ;;
  ""|-h|--help|help)
    cybr::usage; [[ "$cmd" == "" ]] && exit 1 || exit 0 ;;
  *)
    printf 'cybr: unknown command %q\n\n' "$cmd" >&2; cybr::usage >&2; exit 1 ;;
esac
